import { useState } from 'react';
import { X, FileText, CheckSquare, Zap, Download, Layers } from 'lucide-react';

type SetupGuideProps = {
  onClose: () => void;
  onAutoRunDemo?: (files: {
    presentation: File[];
    email: File[];
    evidence: File[];
  }, projectName: string) => void;
};

export function SetupGuide({ onClose, onAutoRunDemo }: SetupGuideProps) {
  const [activeTab, setActiveTab] = useState<'quick' | 'checklist' | 'sql' | 'demos' | 'architecture'>('quick');

  // Helper function to convert text content to File object
  const createFileFromContent = (filename: string, content: string): File => {
    const blob = new Blob([content], { type: 'text/plain' });
    return new File([blob], filename, { type: 'text/plain', lastModified: Date.now() });
  };

  // Auto-run demo for a specific architecture set
  const handleAutoRunDemo = (fileSet: typeof demoFileSets[keyof typeof demoFileSets]) => {
    if (!onAutoRunDemo) return;

    const organizedFiles = {
      presentation: [] as File[],
      email: [] as File[],
      evidence: [] as File[],
    };

    // Organize files by upload zone and extract project name
    let projectName = 'Demo Project';
    Object.entries(fileSet.files).forEach(([filename, content]) => {
      const file = createFileFromContent(filename, content);

      // Try to extract project name from first file
      if (!projectName || projectName === 'Demo Project') {
        const match = content.match(/PROJECT:\s*([^\n]+)/i);
        if (match) {
          projectName = match[1].trim();
        }
      }

      if (filename.includes('Presentation') || filename.includes('RA_')) {
        organizedFiles.presentation.push(file);
      } else if (filename.includes('Email') || filename.includes('Correspondence') || filename.includes('Vendor') || filename.includes('Thread')) {
        organizedFiles.email.push(file);
      } else {
        organizedFiles.evidence.push(file);
      }
    });

    onAutoRunDemo(organizedFiles, projectName);
  };

  const sqlContent = `-- ============================================
-- COMPLETE SUPABASE SETUP - COPY ALL OF THIS
-- ============================================
-- Risk Acceptance Review System - Database Schema
-- Instructions: Copy this entire file, paste in SQL Editor, click Run

-- Enable UUID extension
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- Table: uploaded_files
CREATE TABLE IF NOT EXISTS uploaded_files (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  file_name TEXT NOT NULL,
  file_path TEXT NOT NULL,
  file_size INTEGER NOT NULL,
  file_type TEXT NOT NULL,
  storage_bucket TEXT NOT NULL CHECK (storage_bucket IN ('ra-presentation', 'correspondence', 'supporting-evidence')),
  uploaded_by TEXT NOT NULL,
  project_name TEXT NOT NULL,
  ra_id TEXT,
  metadata JSONB DEFAULT '{}'::jsonb
);

-- Table: risk_acceptances
CREATE TABLE IF NOT EXISTS risk_acceptances (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  ra_id TEXT NOT NULL UNIQUE,
  project_name TEXT NOT NULL,
  submitted_by TEXT NOT NULL,
  submitted_date DATE NOT NULL,
  expiry_date DATE NOT NULL,
  vulnerabilities JSONB NOT NULL DEFAULT '[]'::jsonb,
  proposed_controls TEXT[] NOT NULL DEFAULT '{}',
  supporting_docs TEXT[] NOT NULL DEFAULT '{}',
  recommendation TEXT CHECK (recommendation IN ('APPROVE', 'REJECT', 'REQUEST_INFO')),
  assessment_notes TEXT[] DEFAULT '{}',
  concerns TEXT[] DEFAULT '{}',
  status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'under_review', 'approved', 'rejected'))
);

-- Table: projects
CREATE TABLE IF NOT EXISTS projects (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  project_name TEXT NOT NULL UNIQUE,
  description TEXT,
  architecture_diagram_url TEXT,
  system_type TEXT,
  metadata JSONB DEFAULT '{}'::jsonb
);

-- Create indexes
CREATE INDEX IF NOT EXISTS idx_uploaded_files_created_at ON uploaded_files(created_at DESC);
CREATE INDEX IF NOT EXISTS idx_uploaded_files_bucket ON uploaded_files(storage_bucket);
CREATE INDEX IF NOT EXISTS idx_uploaded_files_project ON uploaded_files(project_name);
CREATE INDEX IF NOT EXISTS idx_uploaded_files_ra_id ON uploaded_files(ra_id);
CREATE INDEX IF NOT EXISTS idx_risk_acceptances_created_at ON risk_acceptances(created_at DESC);
CREATE INDEX IF NOT EXISTS idx_risk_acceptances_ra_id ON risk_acceptances(ra_id);
CREATE INDEX IF NOT EXISTS idx_risk_acceptances_status ON risk_acceptances(status);
CREATE INDEX IF NOT EXISTS idx_projects_name ON projects(project_name);

-- Disable Row Level Security on database tables (for demo)
ALTER TABLE uploaded_files DISABLE ROW LEVEL SECURITY;
ALTER TABLE risk_acceptances DISABLE ROW LEVEL SECURITY;
ALTER TABLE projects DISABLE ROW LEVEL SECURITY;

-- Drop existing storage policies (safe if they don't exist)
DROP POLICY IF EXISTS "Allow all uploads to ra-presentation" ON storage.objects;
DROP POLICY IF EXISTS "Allow all uploads to correspondence" ON storage.objects;
DROP POLICY IF EXISTS "Allow all uploads to supporting-evidence" ON storage.objects;
DROP POLICY IF EXISTS "Allow all reads from ra-presentation" ON storage.objects;
DROP POLICY IF EXISTS "Allow all reads from correspondence" ON storage.objects;
DROP POLICY IF EXISTS "Allow all reads from supporting-evidence" ON storage.objects;
DROP POLICY IF EXISTS "Allow all deletes from ra-presentation" ON storage.objects;
DROP POLICY IF EXISTS "Allow all deletes from correspondence" ON storage.objects;
DROP POLICY IF EXISTS "Allow all deletes from supporting-evidence" ON storage.objects;

-- Create storage policies for uploads
CREATE POLICY "Allow all uploads to ra-presentation" ON storage.objects
FOR INSERT WITH CHECK (bucket_id = 'ra-presentation');

CREATE POLICY "Allow all uploads to correspondence" ON storage.objects
FOR INSERT WITH CHECK (bucket_id = 'correspondence');

CREATE POLICY "Allow all uploads to supporting-evidence" ON storage.objects
FOR INSERT WITH CHECK (bucket_id = 'supporting-evidence');

-- Create storage policies for reads
CREATE POLICY "Allow all reads from ra-presentation" ON storage.objects
FOR SELECT USING (bucket_id = 'ra-presentation');

CREATE POLICY "Allow all reads from correspondence" ON storage.objects
FOR SELECT USING (bucket_id = 'correspondence');

CREATE POLICY "Allow all reads from supporting-evidence" ON storage.objects
FOR SELECT USING (bucket_id = 'supporting-evidence');

-- Create storage policies for deletes
CREATE POLICY "Allow all deletes from ra-presentation" ON storage.objects
FOR DELETE USING (bucket_id = 'ra-presentation');

CREATE POLICY "Allow all deletes from correspondence" ON storage.objects
FOR DELETE USING (bucket_id = 'correspondence');

CREATE POLICY "Allow all deletes from supporting-evidence" ON storage.objects
FOR DELETE USING (bucket_id = 'supporting-evidence');

-- Insert sample project
INSERT INTO projects (project_name, description, system_type) VALUES
('E-Government Payment Gateway', '3-tier web application for citizen payment services', '3-tier-web-application')
ON CONFLICT (project_name) DO NOTHING;

-- Insert sample risk acceptance
INSERT INTO risk_acceptances (
  ra_id, project_name, submitted_by, submitted_date, expiry_date, vulnerabilities, proposed_controls, supporting_docs, recommendation, assessment_notes, concerns, status
) VALUES (
  'RA-2026-0042',
  'E-Government Payment Gateway',
  'Officer 1 (Product Security)',
  '2026-04-10',
  '2026-07-10',
  '[{"cveId": "CVE-2024-3457", "severity": "MEDIUM"}]'::jsonb,
  ARRAY['The server is hosted in the internal network which is only accessible by CAM and can only be accessed by authorized user.', 'The web application is not used by any other users except Good Luck Infra.', 'Firewall and IPS solution are implemented within the Good Luck Infra with network monitoring in place to aid in the detection of any potential malicious or unauthorized activities.'],
  ARRAY['Test for Hackathon_desens.pptx', 'Test_VMS_report.xlsm', 'Vendor_pdf.pdf'],
  'APPROVE',
  ARRAY['Analyzed 3 supporting documents from submission.', 'Business case presentation (Test for Hackathon_desens.pptx) provides clear justification and timeline.', 'Proposed compensating controls are comprehensive and address key attack vectors.', 'Supporting evidence (Test_VMS_report.xlsm) validates finding severity.', 'Email correspondence (Vendor_pdf.pdf) shows alignment and constraints.'],
  ARRAY[]::TEXT[],
  'approved'
)
ON CONFLICT (ra_id) DO NOTHING;

SELECT 'Database schema created successfully!' AS status;`;

  const demoFileSets = {
    '3tier': {
      name: '3-Tier Web Application',
      description: 'Traditional 3-tier architecture with internal network deployment',
      files: {
        'RA_Presentation_3Tier_Payment_Gateway.txt': `═══════════════════════════════════════════════════════════════════════════
RISK ACCEPTANCE SUBMISSION - 3-TIER WEB APPLICATION
═══════════════════════════════════════════════════════════════════════════

PROJECT: E-Government Payment Gateway
ARCHITECTURE TYPE: 3-Tier Web Application
SUBMISSION ID: RA-2026-0042
DATE: April 10, 2026

───────────────────────────────────────────────────────────────────────────
SYSTEM ARCHITECTURE OVERVIEW
───────────────────────────────────────────────────────────────────────────

The E-Government Payment Gateway follows a traditional 3-tier architecture:

PRESENTATION LAYER:
- Web Interface: React-based frontend application
- User Interface: Citizen-facing payment forms
- Access: Internal network only via CAM (Centralized Access Management)

APPLICATION LAYER:
- Payment Gateway API: RESTful API services
- Business Logic: Transaction processing, validation, routing
- Backend Server: Node.js application server
- Authentication: Basic authentication with session management

DATA LAYER:
- Database Server: PostgreSQL 14.2
- Data Storage: Transaction records, user profiles, audit logs
- Location: Internal network, separate subnet

INFRASTRUCTURE:
- Deployment: On-premise internal network
- Security Perimeter: Firewall and IPS solution
- Network Monitoring: SIEM integration for threat detection
- Load Balancing: Not currently implemented

───────────────────────────────────────────────────────────────────────────
VULNERABILITY DETAILS
───────────────────────────────────────────────────────────────────────────

CVE ID: CVE-2024-3457
CVSS Score: 6.5 (MEDIUM)
Component: Payment Gateway API
Impact: Information disclosure vulnerability

───────────────────────────────────────────────────────────────────────────
COMPENSATING CONTROLS
───────────────────────────────────────────────────────────────────────────

1. Network Segmentation: Internal network only, no public internet access
2. Firewall Rules: IPS monitoring all traffic
3. Access Control: Restricted to authorized CAM users only
4. Monitoring: 24/7 SIEM monitoring and alerting

ACCEPTANCE PERIOD: 90 days (decommissioning scheduled July 2026)
═══════════════════════════════════════════════════════════════════════════`,

        'Architecture_Diagram_Description.txt': `═══════════════════════════════════════════════════════════════════════════
