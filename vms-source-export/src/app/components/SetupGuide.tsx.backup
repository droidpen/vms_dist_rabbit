  };

  const downloadFile = (filename: string, content: string, projectPrefix?: string) => {
    const blob = new Blob([content], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;

    // Add project name prefix if provided
    if (projectPrefix) {
      // Sanitize project name for filename (replace spaces with underscores, remove special chars)
      const sanitizedPrefix = projectPrefix
        .replace(/[^a-zA-Z0-9\s-]/g, '')
        .replace(/\s+/g, '_')
        .substring(0, 50); // Limit length
      a.download = `${sanitizedPrefix}_${filename}`;
    } else {
      a.download = filename;
    }

    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  };

  const copyToClipboard = (text: string) => {
    // Fallback copy method that doesn't use Clipboard API
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();

    try {
      document.execCommand('copy');
      alert('✅ SQL copied to clipboard! Paste it in Supabase SQL Editor.');
    } catch (err) {
      alert('❌ Copy failed. Please manually select and copy the SQL below.');
    }

    document.body.removeChild(textarea);
  };

  return (
