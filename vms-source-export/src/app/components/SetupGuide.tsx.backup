                const projectPrefix = projectMatch ? projectMatch[1].trim() : fileSet.name;

                return (
                  <div key={key} className="border-2 border-border rounded-lg p-4 bg-card">
                    <div className="mb-4">
                      <h3 className="font-medium text-lg mb-1">{fileSet.name}</h3>
                      <p className="text-sm text-muted-foreground">{fileSet.description}</p>
                    </div>

                    <div className="space-y-3">
                      {Object.entries(fileSet.files).map(([filename, content]) => {
                        // Determine upload zone
                        const uploadZone = filename.includes('Presentation') || filename.includes('RA_')
                          ? { name: 'RA Presentation', color: 'bg-blue-100 text-blue-800 border-blue-300' }
                          : filename.includes('Email') || filename.includes('Correspondence') || filename.includes('Vendor') || filename.includes('Thread')
                          ? { name: 'Correspondence', color: 'bg-purple-100 text-purple-800 border-purple-300' }
                          : { name: 'Supporting Evidence', color: 'bg-green-100 text-green-800 border-green-300' };

                        return (
                          <div key={filename} className="border-2 border-border rounded bg-card p-3">
                            <div className="flex items-start justify-between mb-2 gap-3">
                              <div className="flex-1">
                                <div className="flex items-center gap-2 mb-2">
                                  <FileText className="w-4 h-4 text-primary flex-shrink-0" />
                                  <span className="font-medium text-sm">{filename}</span>
                                </div>
                                <div className={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded border ${uploadZone.color} text-xs font-medium`}>
                                  <span>📤 Upload to:</span>
                                  <span className="font-bold">{uploadZone.name}</span>
                                </div>
                              </div>
                              <button
                                onClick={() => downloadFile(filename, content, projectPrefix)}
                                className="px-3 py-1.5 bg-primary text-primary-foreground rounded hover:opacity-90 flex items-center gap-1.5 text-xs flex-shrink-0"
                              >
                                <Download className="w-3.5 h-3.5" />
                                Download
                              </button>
                            </div>
                            <div className="text-xs text-muted-foreground mt-2">
                              {content.length.toLocaleString()} characters • Downloaded as: <span className="font-mono">{projectPrefix.replace(/[^a-zA-Z0-9\s-]/g, '').replace(/\s+/g, '_').substring(0, 50)}_{filename}</span>
                            </div>
                          </div>
                        );
                      })}
                    </div>

                    <div className="mt-3 pt-3 border-t border-border space-y-2">
                      <button
                        onClick={() => {
                          Object.entries(fileSet.files).forEach(([filename, content]) => {
                            downloadFile(filename, content, projectPrefix);
                          });
                        }}
                        className="w-full px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 flex items-center justify-center gap-2"
                      >
                        <Download className="w-4 h-4" />
                        Download All {Object.keys(fileSet.files).length} Files
                      </button>
                    {onAutoRunDemo && (
                      <button
                        onClick={() => handleAutoRunDemo(fileSet)}
                        className="w-full px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 flex items-center justify-center gap-2 font-medium"
                      >
                        <span className="text-lg">▶️</span>
                        Auto Run Demo (Instant Analysis!)
                      </button>
                    )}
                  </div>
                </div>
                );
              })}

              <div className="bg-green-50 border border-green-200 rounded p-4 mt-6">
                <h4 className="font-medium mb-3">💡 How to Use These Demo Files</h4>
                <div className="bg-white border-2 border-green-300 rounded p-3 mb-3">
                  <div className="flex items-center gap-2 mb-2">
                    <span className="text-2xl">⚡</span>
                    <span className="font-bold text-green-800">Quick Demo (Recommended!)</span>
                  </div>
                  <p className="text-sm mb-2">
                    Click <strong>"Auto Run Demo"</strong> button to instantly populate upload boxes and see architecture analysis in action!
                  </p>
                  <p className="text-xs text-green-700">
                    The setup guide will close automatically and you'll see the results immediately.
                  </p>
                </div>
                <div className="text-sm mb-2 font-medium">Or, manually download and upload:</div>
                <ol className="list-decimal list-inside text-sm space-y-2">
                  <li>Choose an architecture type above (3-Tier, Microservices, AI/ML, or Serverless)</li>
                  <li>Click "Download All Files" to get the complete set (4 files per architecture)
                    <div className="text-xs text-muted-foreground ml-6 mt-1">
                      ℹ️ Files are automatically prefixed with project name for organization
                    </div>
                  </li>
                  <li>Each file has a <strong>color-coded badge</strong> showing which upload zone to use:
                    <ul className="list-none ml-6 mt-2 space-y-2">
                      <li className="flex items-center gap-2">
                        <span className="inline-block px-2 py-0.5 rounded border bg-blue-100 text-blue-800 border-blue-300 text-xs font-bold">RA Presentation</span>
                        <span>→ Upload to the <strong>left box</strong></span>
                      </li>
                      <li className="flex items-center gap-2">
                        <span className="inline-block px-2 py-0.5 rounded border bg-purple-100 text-purple-800 border-purple-300 text-xs font-bold">Correspondence</span>
                        <span>→ Upload to the <strong>middle box</strong></span>
                      </li>
                      <li className="flex items-center gap-2">
                        <span className="inline-block px-2 py-0.5 rounded border bg-green-100 text-green-800 border-green-300 text-xs font-bold">Supporting Evidence</span>
                        <span>→ Upload to the <strong>right box</strong></span>
                      </li>
                    </ul>
                  </li>
                  <li>Watch the System Architecture Analysis box automatically identify:
                    <ul className="list-disc list-inside ml-6 mt-1.5 space-y-1">
                      <li>Architecture type (3-tier, microservices, serverless, etc.)</li>
                      <li>Components (API gateway, databases, containers, ML models)</li>
                      <li>AI/ML systems (triggers MITRE ATLAS framework)</li>
                      <li>Deployment model (cloud vs internal network)</li>
                    </ul>
                  </li>
                  <li>See the Threat Modeling Analysis box generate:
                    <ul className="list-disc list-inside ml-6 mt-1.5 space-y-1">
                      <li>MITRE ATT&CK tactics tailored to the architecture</li>
                      <li>MITRE ATLAS tactics for AI/ML systems</li>
                      <li>Network diagram showing attack surface</li>
                      <li>Specific techniques (T-codes) relevant to the system</li>
                    </ul>
                  </li>
                  <li><strong>📧 Pro Tip:</strong> Read the vendor correspondence files - they contain patch timelines (e.g., "patch won't be ready for 3 months") that justify the risk acceptance decisions!</li>
                </ol>
              </div>

              <div className="bg-yellow-50 border border-yellow-200 rounded p-4">
                <h4 className="font-medium mb-2">🎯 What Each File Set Demonstrates</h4>
                <div className="space-y-3 text-sm">
                  <div>
                    <strong>3-Tier Web Application:</strong> Traditional architecture with presentation, application, and data layers. Internal network deployment with firewall/IPS.
                    <br/>
                    <span className="text-xs text-yellow-800">📧 Vendor email: 3-month patch delay → justifies 90-day risk acceptance</span>
                  </div>
                  <div>
                    <strong>Microservices Architecture:</strong> Cloud-native with Kubernetes, API Gateway (Kong), multiple services, container security, and service mesh (Istio).
                    <br/>
                    <span className="text-xs text-yellow-800">📧 Kong vendor: 60-day patch timeline + migration complexity → off-peak season acceptance</span>
                  </div>
                  <div>
                    <strong>AI/ML System:</strong> Triggers both MITRE ATT&CK and ATLAS frameworks. Includes TensorFlow, model inference, training pipelines, and adversarial defense.
                    <br/>
                    <span className="text-xs text-yellow-800">📧 TensorFlow team: 45-day patch + model re-export requirements → aligns with model retraining cycle</span>
                  </div>
                  <div>
                    <strong>Serverless Architecture:</strong> Event-driven FaaS with AWS Lambda, API Gateway, S3, DynamoDB. Demonstrates serverless-specific threat modeling.
                    <br/>
                    <span className="text-xs text-yellow-800">📧 AWS: 30-day runtime update + automatic deployment → minimal risk window</span>
                  </div>
                </div>
              </div>

              {/* Legacy demo files for backward compatibility */}
              <div className="border-t-2 border-border pt-6 mt-6">
                <h3 className="font-medium mb-3">Legacy Demo Files (Original)</h3>
                {Object.entries(legacyDemoFiles).map(([filename, content]) => {
                  // Determine upload zone for legacy files
                  const uploadZone = filename.includes('Hackathon')
                    ? { name: 'RA Presentation', color: 'bg-blue-100 text-blue-800 border-blue-300' }
                    : filename.includes('correspondence') || filename.includes('Vendor')
                    ? { name: 'Correspondence', color: 'bg-purple-100 text-purple-800 border-purple-300' }
                    : { name: 'Supporting Evidence', color: 'bg-green-100 text-green-800 border-green-300' };

                  // Use legacy project name for prefix
                  const legacyProjectPrefix = 'E-Government Payment Gateway';

                  return (
                    <div key={filename} className="border border-border rounded-lg p-4 mb-3">
                      <div className="flex items-start justify-between mb-3 gap-3">
                        <div className="flex-1">
                          <div className="flex items-center gap-2 mb-2">
                            <FileText className="w-5 h-5 text-primary" />
                            <h4 className="font-medium">{filename}</h4>
                          </div>
                          <div className={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded border ${uploadZone.color} text-xs font-medium`}>
                            <span>📤 Upload to:</span>
                            <span className="font-bold">{uploadZone.name}</span>
                          </div>
                        </div>
                        <button
                          onClick={() => downloadFile(filename, content, legacyProjectPrefix)}
                          className="px-4 py-2 bg-primary text-primary-foreground rounded hover:opacity-90 flex items-center gap-2 flex-shrink-0"
                        >
                          <Download className="w-4 h-4" />
                          Download
                        </button>
                      </div>
                      <div className="bg-secondary p-3 rounded max-h-40 overflow-y-auto">
                        <pre className="text-xs font-mono whitespace-pre-wrap">{content.substring(0, 500)}...</pre>
                      </div>
                      <p className="text-xs text-muted-foreground mt-2">
                        {content.length.toLocaleString()} characters
                      </p>
                    </div>
                  );
                })}

              <div className="bg-gray-50 border border-gray-300 rounded p-4 mt-4">
                <h4 className="font-medium mb-2">ℹ️ Legacy Files Note</h4>
                <p className="text-sm text-muted-foreground mb-2">
                  These are the original demo files. For better architecture analysis demonstrations,
                  use the <strong>new architecture-specific file sets above</strong>.
                </p>
                <p className="text-xs text-muted-foreground">
                  Each legacy file is also color-coded to show which upload zone to use.
                </p>
              </div>
              </div>
            </div>
          )}

          {activeTab === 'architecture' && (
            <div className="space-y-6">
              <div className="bg-blue-50 border border-blue-200 rounded p-4">
                <h3 className="font-medium mb-2">🏗️ System Architecture Analysis</h3>
                <p className="text-sm text-muted-foreground mb-2">
                  The app automatically analyzes uploaded files to identify system architecture and generate threat models using MITRE ATT&CK and ATLAS frameworks.
                </p>
                <div className="bg-white border border-blue-300 rounded px-3 py-2 text-xs mt-2">
                  <strong>💡 Quick Start:</strong> Go to "Demo Files" tab and click <strong>"Auto Run Demo"</strong> to see this in action instantly!
                </div>
              </div>

              <div className="space-y-4">
                <div className="border border-border rounded-lg p-4">
                  <h3 className="font-medium mb-3">How Architecture Synthesis Works</h3>
                  <p className="text-sm mb-3">When you upload files, the system analyzes them to automatically:</p>
                  <ol className="list-decimal list-inside space-y-2 text-sm">
                    <li><strong>Identify Architecture Type:</strong> 3-tier, microservices, serverless, monolithic, SOA, event-driven</li>
                    <li><strong>Extract Components:</strong> Frontend, backend, database, API gateway, caching layers, security infrastructure</li>
                    <li><strong>Detect AI/ML Systems:</strong> Machine learning models, neural networks, training pipelines</li>
                    <li><strong>Determine Deployment:</strong> Cloud vs internal network, containerized environments</li>
                    <li><strong>Calculate Confidence:</strong> Score and explanation of why the architecture was identified</li>
                  </ol>
                </div>

                <div className="border border-border rounded-lg p-4">
                  <h3 className="font-medium mb-3">Architecture Patterns Detected</h3>
                  <div className="grid grid-cols-2 gap-3 text-sm">
                    <div>
                      <h4 className="font-medium mb-2">Architecture Types:</h4>
                      <ul className="list-disc list-inside space-y-1 text-muted-foreground">
                        <li>Microservices</li>
                        <li>3-Tier Web Application</li>
                        <li>Serverless / FaaS</li>
                        <li>Monolithic</li>
                        <li>Service-Oriented (SOA)</li>
                        <li>Event-Driven</li>
                      </ul>
                    </div>
                    <div>
                      <h4 className="font-medium mb-2">Components Identified:</h4>
                      <ul className="list-disc list-inside space-y-1 text-muted-foreground">
                        <li>Frontend / UI Layer</li>
                        <li>Backend / API Services</li>
                        <li>Database / Data Layer</li>
                        <li>Caching (Redis, Memcache)</li>
                        <li>Load Balancers</li>
                        <li>Firewall / IPS / WAF</li>
                        <li>Kubernetes / Containers</li>
                      </ul>
                    </div>
                  </div>
                </div>

                <div className="border border-border rounded-lg p-4">
                  <h3 className="font-medium mb-3">Keywords the System Looks For</h3>
                  <p className="text-sm mb-3">To get accurate architecture identification, include these keywords in your documents:</p>
                  <div className="space-y-3 text-sm">
                    <div className="bg-secondary p-3 rounded">
                      <h4 className="font-medium mb-1">For Architecture Type:</h4>
                      <code className="text-xs">microservice, 3-tier, three tier, serverless, lambda, monolith, SOA, event-driven, kubernetes, container</code>
                    </div>
                    <div className="bg-secondary p-3 rounded">
                      <h4 className="font-medium mb-1">For Components:</h4>
                      <code className="text-xs">frontend, backend, database, API gateway, load balancer, firewall, IPS, WAF, cache, redis</code>
                    </div>
                    <div className="bg-secondary p-3 rounded">
                      <h4 className="font-medium mb-1">For AI/ML Detection:</h4>
                      <code className="text-xs">machine learning, ML model, neural network, AI, tensorflow, pytorch, inference, training</code>
                    </div>
                    <div className="bg-secondary p-3 rounded">
                      <h4 className="font-medium mb-1">For Deployment:</h4>
                      <code className="text-xs">cloud, AWS, Azure, GCP, internal network, on-premise, on-prem</code>
                    </div>
                  </div>
                </div>

                <div className="border border-border rounded-lg p-4">
                  <h3 className="font-medium mb-3">Threat Modeling (MITRE ATT&CK & ATLAS)</h3>
                  <p className="text-sm mb-3">Once architecture is identified, the system generates:</p>
                  <ul className="list-disc list-inside space-y-2 text-sm">
                    <li><strong>MITRE ATT&CK Tactics:</strong> Tailored to detected architecture (e.g., container-specific tactics for Kubernetes)</li>
                    <li><strong>MITRE ATLAS Tactics:</strong> AI/ML-specific threats when AI systems are detected</li>
                    <li><strong>Network Diagram:</strong> Visual attack surface map showing threat vectors and vulnerable components</li>
                    <li><strong>Technique Mapping:</strong> Specific techniques (T-codes) relevant to your architecture</li>
                  </ul>
                </div>

                <div className="bg-green-50 border border-green-200 rounded p-4">
                  <h3 className="font-medium mb-2">💡 Best Practices for Accurate Analysis</h3>
                  <ol className="list-decimal list-inside text-sm space-y-1">
                    <li><strong>Use Pre-Made Demo Files:</strong> Download from "Demo Files" tab to see instant results</li>
                    <li>Include architecture diagrams in presentations or evidence files</li>
                    <li>Mention specific technologies and components in your documents</li>
                    <li>Describe deployment environment (cloud provider, internal network, etc.)</li>
                    <li>List layers: presentation, application, data, or service names</li>
                    <li>Mention security infrastructure: firewalls, IPS, WAF, monitoring</li>
                    <li>For AI systems: specify ML frameworks, model types, inference/training</li>
                  </ol>
                </div>

                <div className="bg-purple-50 border border-purple-200 rounded p-4">
                  <h3 className="font-medium mb-2">🎯 Try the Demo File Sets</h3>
                  <p className="text-sm mb-3">
                    Go to the <strong>"Demo Files"</strong> tab to download pre-made file sets that demonstrate:
                  </p>
                  <ul className="list-disc list-inside text-sm space-y-1.5">
                    <li><strong>3-Tier:</strong> Classic web app with presentation/application/data layers</li>
                    <li><strong>Microservices:</strong> Kubernetes + Kong API Gateway + service mesh</li>
                    <li><strong>AI/ML:</strong> Triggers MITRE ATLAS framework with ML models and inference</li>
                    <li><strong>Serverless:</strong> AWS Lambda + event-driven architecture</li>
                  </ul>
                  <p className="text-sm mt-3">
                    Each set contains 4 files: RA presentation, vendor correspondence (patch timelines!), architecture docs, and security assessment - everything needed for realistic risk acceptance decisions!
                  </p>
                </div>

                <div className="bg-yellow-50 border border-yellow-200 rounded p-4">
                  <h3 className="font-medium mb-2">⚠️ Important Notes</h3>
                  <ul className="list-disc list-inside text-sm space-y-1">
                    <li>Analysis updates automatically when files are uploaded or removed</li>
                    <li>Both analysis boxes are collapsible - click headers to expand/collapse</li>
                    <li>Confidence scores indicate analysis quality (higher is better)</li>
                    <li>If architecture type is "Unknown", add more descriptive keywords to your files</li>
                    <li>Network diagrams are auto-generated based on detected components</li>
                  </ul>
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Footer */}
        <div className="border-t border-border px-6 py-4 bg-muted/30">
          <p className="text-sm text-muted-foreground">
            📖 Supabase Dashboard: <a href="https://supabase.com/dashboard/project/rcojgwrpyurkwbvlyxmi" target="_blank" className="text-blue-600 underline">Open here</a>
          </p>
        </div>
      </div>
    </div>
  );
}
